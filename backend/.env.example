# Paper Plane - Production Configuration Example
# Copy this file to .env and replace placeholders with real values.

# Server port (Railway sets this automatically, but useful for local dev)
PORT=3001

# PostgreSQL connection string
# Railway provides this automatically as DATABASE_URL in production.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# AI Engine: Set your Gemini API key to switch from rule-based to LLM.
# Leave blank to use the local rule-based scoring engine (no API key needed).
GEMINI_API_KEY=

# Environment (development / production)
NODE_ENV=production
