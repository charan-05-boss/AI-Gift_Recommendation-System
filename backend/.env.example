# Paper Plane - Backend Configuration

# Server port (default: 3001)
PORT=3001

# PostgreSQL connection string
# For local dev: postgres://postgres:password@localhost:5432/gift_assistant
# Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# AI Engine: Set your Gemini API key to switch from rule-based to LLM.
# Leave blank to use the local rule-based scoring engine (no API key needed).
GEMINI_API_KEY=

# Environment (development / production)
NODE_ENV=development
